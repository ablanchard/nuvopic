# =============================================================================
# Database (PostgreSQL with pgvector extension)
# Any PostgreSQL provider works: Supabase, Neon, AWS RDS, self-hosted, etc.
# =============================================================================
DATABASE_URL=postgres://user:password@host:5432/dbname
# Set to "true" to enable SSL connections (required for most cloud providers)
# DATABASE_SSL=true

# =============================================================================
# S3-compatible Object Storage
# Works with: AWS S3, Scaleway Object Storage, Cloudflare R2, MinIO, etc.
# =============================================================================
S3_BUCKET=my-photos
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=us-east-1
# Custom endpoint for non-AWS providers (e.g., https://s3.fr-par.scw.cloud)
# S3_ENDPOINT=https://s3.provider.com
# Required for MinIO and some S3-compatible providers
# S3_FORCE_PATH_STYLE=true

# =============================================================================
# Authentication (optional - if not set, the app is publicly accessible)
# =============================================================================
# Password to access the application (single-user auth)
# AUTH_PASSWORD=your-secure-password
# Secret key for signing session tokens (generate with: openssl rand -hex 32)
# JWT_SECRET=your-random-secret

# =============================================================================
# Processing Mode (optional)
# "modal" = GPU-accelerated via Modal (requires MODAL_* vars below)
# "local" = CPU-based, uses @xenova/transformers + face-api.js
# If not set, auto-detects: uses Modal if MODAL_ENDPOINT_URL is configured
# =============================================================================
# PROCESSING_MODE=modal

# =============================================================================
# Modal GPU Inference (required when PROCESSING_MODE=modal)
# Deploy the endpoint with: modal deploy modal/inference.py
# =============================================================================
# MODAL_ENDPOINT_URL=https://your-workspace--nuvopic-inference-analyze.modal.run
# MODAL_PROXY_KEY=ak-xxx
# MODAL_PROXY_SECRET=as-xxx

# =============================================================================
# Server
# =============================================================================
# PORT=8080
# LOG_LEVEL=info
